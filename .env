GEYSER_DOMAIN=geyser-dev.univ-lille.fr
GEYSER_MODE=development
GEYSER_TAG=univ-lille
GEYSER_LOG_LEVEL=debug
GEYSER_AS_SERVICE=false

# Security Notice: These are example passwords for development only.
# For your own installation:
# 1. Copy these password variables to a new file named .env.local
# 2. Change all passwords to strong, unique values
# 3. Keep .env.local out of version control (add it to .gitignore)
